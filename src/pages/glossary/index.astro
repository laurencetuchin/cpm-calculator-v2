---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { glossaryTerms } from '~/data/glossary';

const metadata = {
  title: 'Marketing & Advertising Glossary | CPM Calculator',
  description:
    'Free marketing and advertising glossary. Clear definitions for CPM, CPC, CPA, ROAS, CAC, LTV, CTR, and 15+ more key advertising metrics — with formulas and examples.',
  canonical: 'https://cpmcalculator.online/glossary',
  robots: { index: true, follow: true },
  openGraph: {
    type: 'website',
    url: 'https://cpmcalculator.online/glossary',
    title: 'Marketing & Advertising Glossary | CPM Calculator',
    description: 'Definitions, formulas, and examples for the most important advertising and marketing metrics.',
  },
};

const categories = ['Paid Advertising', 'Analytics', 'E-commerce', 'Social Media', 'General'] as const;

const categoryColors: Record<string, string> = {
  'Paid Advertising': 'from-purple-500 to-pink-500',
  Analytics: 'from-blue-500 to-cyan-500',
  'E-commerce': 'from-green-500 to-emerald-500',
  'Social Media': 'from-pink-500 to-rose-500',
  General: 'from-gray-500 to-slate-500',
};

const categoryBg: Record<string, string> = {
  'Paid Advertising': 'from-purple-500/20 to-pink-500/20 border-purple-500/20',
  Analytics: 'from-blue-500/20 to-cyan-500/20 border-blue-500/20',
  'E-commerce': 'from-green-500/20 to-emerald-500/20 border-green-500/20',
  'Social Media': 'from-pink-500/20 to-rose-500/20 border-pink-500/20',
  General: 'from-gray-500/20 to-slate-500/20 border-gray-500/20',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <section class="relative not-prose overflow-hidden min-h-[40vh] flex items-center">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute left-1/2 top-0 -translate-x-1/2 w-[1000px] h-[500px] bg-purple-600/30 blur-[120px] rounded-full mix-blend-screen animate-blob"></div>
      <div class="absolute right-0 top-1/4 w-[800px] h-[600px] bg-blue-600/20 blur-[100px] rounded-full mix-blend-screen animate-blob animation-delay-2000"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 w-full">
      <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
      <div class="py-12 md:py-20 text-center">
        <p class="text-base font-bold tracking-wide uppercase bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-600 animate-fade-in-up mb-4">
          Marketing Reference
        </p>
        <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-6 font-heading dark:text-gray-200 animate-fade-in-up animation-delay-150">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-pink-600">Advertising Glossary</span>
        </h1>
        <p class="text-xl text-muted dark:text-slate-300 max-w-2xl mx-auto animate-fade-in-up animation-delay-300">
          Clear definitions for every metric that matters — with formulas, examples, and links to free calculators.
        </p>
        <p class="mt-3 text-sm text-gray-500 animate-fade-in-up animation-delay-450">
          {glossaryTerms.length} terms across {categories.length} categories
        </p>
      </div>
    </div>
  </section>

  <!-- Term Grid -->
  <section class="px-4 sm:px-6 mx-auto lg:px-8 max-w-6xl pb-20">

    <!-- Category sections -->
    {categories.map((cat) => {
      const terms = glossaryTerms.filter((t) => t.category === cat);
      if (terms.length === 0) return null;
      return (
        <div class="mb-14">
          <div class="flex items-center gap-3 mb-6">
            <div class={`h-px flex-1 bg-gradient-to-r ${categoryColors[cat]} opacity-30`}></div>
            <span class={`text-sm font-semibold tracking-widest uppercase bg-clip-text text-transparent bg-gradient-to-r ${categoryColors[cat]}`}>
              {cat}
            </span>
            <div class={`h-px flex-1 bg-gradient-to-l ${categoryColors[cat]} opacity-30`}></div>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {terms.map((term) => (
              <a
                href={`/glossary/${term.slug}`}
                class={`group p-5 rounded-2xl bg-gradient-to-br ${categoryBg[cat]} border backdrop-blur-sm hover:scale-[1.02] transition-all duration-300`}
              >
                <div class="flex items-start justify-between mb-2">
                  <div>
                    {term.abbreviation && (
                      <span class={`text-xs font-bold tracking-widest uppercase bg-clip-text text-transparent bg-gradient-to-r ${categoryColors[cat]}`}>
                        {term.abbreviation}
                      </span>
                    )}
                    <h2 class="text-base font-bold text-white mt-0.5">{term.term}</h2>
                  </div>
                  <Icon name="tabler:arrow-up-right" class="w-4 h-4 text-white/30 group-hover:text-white/70 transition-colors flex-shrink-0 mt-1" />
                </div>
                <p class="text-sm text-gray-400 leading-relaxed">{term.shortDefinition}</p>
              </a>
            ))}
          </div>
        </div>
      );
    })}

    <!-- Compare CTA -->
    <div class="mt-8 bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8 text-center shadow-[0_0_40px_rgba(139,92,246,0.1)]">
      <Icon name="tabler:arrows-exchange" class="w-10 h-10 text-purple-400 mx-auto mb-4" />
      <h2 class="text-2xl font-bold text-white mb-2">Not sure which metric to use?</h2>
      <p class="text-gray-400 mb-6 max-w-xl mx-auto">
        See our comparison guides for side-by-side breakdowns of the most commonly confused advertising metrics.
      </p>
      <a
        href="/compare"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold hover:opacity-90 transition-opacity"
      >
        View Comparisons
        <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </section>
</Layout>

<style>
  .animate-blob { animation: blob 7s infinite; }
  .animation-delay-2000 { animation-delay: 2s; }
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  .animation-delay-150 { animation-delay: 150ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-450 { animation-delay: 450ms; }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
