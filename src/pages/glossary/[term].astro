---
import Layout from '~/layouts/PageLayout.astro';
import RelatedTools from '~/components/common/RelatedTools.astro';
import { Icon } from 'astro-icon/components';
import { glossaryTerms, getRelatedTerms, type GlossaryTerm } from '~/data/glossary';

export function getStaticPaths() {
  return glossaryTerms.map((term) => ({
    params: { term: term.slug },
    props: { term },
  }));
}

interface Props {
  term: GlossaryTerm;
}

const { term } = Astro.props;
const relatedTerms = getRelatedTerms(term.relatedTerms);

const metadata = {
  title: `${term.abbreviation ? term.abbreviation + ' — ' : ''}${term.term} Definition | Advertising Glossary`,
  description: `${term.shortDefinition}${term.formula ? ' Formula: ' + term.formula : ''} Free marketing glossary with examples.`,
  canonical: `https://cpmcalculator.online/glossary/${term.slug}`,
  robots: { index: true, follow: true },
  openGraph: {
    type: 'article',
    url: `https://cpmcalculator.online/glossary/${term.slug}`,
    title: `What is ${term.abbreviation || term.term}? Definition & Examples`,
    description: term.shortDefinition,
  },
};

const categoryGradients: Record<string, string> = {
  'Paid Advertising': 'from-purple-400 to-pink-600',
  Analytics: 'from-blue-400 to-cyan-600',
  'E-commerce': 'from-green-400 to-emerald-600',
  'Social Media': 'from-pink-400 to-rose-600',
  General: 'from-gray-400 to-slate-600',
};

const gradient = categoryGradients[term.category] ?? 'from-purple-400 to-pink-600';
---

<Layout metadata={metadata}>
  <!-- Breadcrumb -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 md:pt-[96px]">
    <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <Icon name="tabler:chevron-right" class="w-4 h-4" />
      <a href="/glossary" class="hover:text-white transition-colors">Glossary</a>
      <Icon name="tabler:chevron-right" class="w-4 h-4" />
      <span class="text-gray-300">{term.abbreviation || term.term}</span>
    </nav>
  </div>

  <!-- Hero -->
  <section class="relative not-prose overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute left-1/2 top-0 -translate-x-1/2 w-[800px] h-[400px] bg-purple-600/20 blur-[120px] rounded-full mix-blend-screen"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-10 md:py-16">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-bold tracking-widest uppercase bg-clip-text text-transparent bg-gradient-to-r ${gradient}`}>
            {term.category}
          </span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tight mb-4 font-heading">
          {term.abbreviation ? (
            <>
              <span class={`bg-clip-text text-transparent bg-gradient-to-r ${gradient}`}>{term.abbreviation}</span>
              <span class="text-gray-300"> — {term.term}</span>
            </>
          ) : (
            <span class={`bg-clip-text text-transparent bg-gradient-to-r ${gradient}`}>{term.term}</span>
          )}
        </h1>
        <p class="text-xl text-gray-300 max-w-3xl leading-relaxed">{term.shortDefinition}</p>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="px-4 sm:px-6 mx-auto lg:px-8 max-w-6xl pb-20">
    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Left: Main content -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Full definition -->
        <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8 shadow-[0_0_40px_rgba(139,92,246,0.05)]">
          <div class="flex items-center mb-5">
            <Icon name="tabler:book" class={`w-7 h-7 mr-3 bg-clip-text`} style={`color: #a855f7`} />
            <h2 class="text-2xl font-bold text-white">Definition</h2>
          </div>
          <p class="text-gray-300 leading-relaxed text-lg">{term.fullDefinition}</p>
        </div>

        <!-- Formula -->
        {term.formula && (
          <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8 shadow-[0_0_40px_rgba(59,130,246,0.05)]">
            <div class="flex items-center mb-5">
              <Icon name="tabler:math" class="w-7 h-7 text-blue-400 mr-3" />
              <h2 class="text-2xl font-bold text-white">Formula</h2>
            </div>
            <div class="bg-gradient-to-r from-purple-500/10 to-blue-500/10 p-5 rounded-2xl border border-purple-500/20 mb-4">
              <code class="text-purple-300 font-mono text-base">{term.formula}</code>
            </div>
            {term.formulaDescription && (
              <p class="text-gray-400">{term.formulaDescription}</p>
            )}
          </div>
        )}

        <!-- Example -->
        {term.example && (
          <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8">
            <div class="flex items-center mb-5">
              <Icon name="tabler:bulb" class="w-7 h-7 text-yellow-400 mr-3" />
              <h2 class="text-2xl font-bold text-white">Example</h2>
            </div>
            <div class="bg-gradient-to-r from-yellow-500/10 to-orange-500/10 p-5 rounded-2xl border border-yellow-500/20">
              <p class="text-gray-200 leading-relaxed">{term.example}</p>
            </div>
          </div>
        )}

        <!-- Key points -->
        <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8">
          <div class="flex items-center mb-5">
            <Icon name="tabler:list-check" class="w-7 h-7 text-green-400 mr-3" />
            <h2 class="text-2xl font-bold text-white">Key Points</h2>
          </div>
          <ul class="space-y-3">
            {term.keyPoints.map((point) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 w-5 h-5 rounded-full bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center mt-0.5">
                  <Icon name="tabler:check" class="w-3 h-3 text-white" />
                </span>
                <span class="text-gray-300">{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Benchmarks -->
        {term.benchmarks && term.benchmarks.length > 0 && (
          <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-8">
            <div class="flex items-center mb-5">
              <Icon name="tabler:chart-bar" class="w-7 h-7 text-pink-400 mr-3" />
              <h2 class="text-2xl font-bold text-white">Industry Benchmarks</h2>
            </div>
            <div class="space-y-3">
              {term.benchmarks.map((b) => (
                <div class="flex items-center justify-between p-4 rounded-xl bg-gradient-to-r from-white/5 to-transparent border border-white/10 hover:border-white/20 transition-all">
                  <div>
                    <span class="font-semibold text-gray-200">{b.label}</span>
                    {b.note && <p class="text-xs text-gray-500 italic mt-0.5">{b.note}</p>}
                  </div>
                  <span class={`font-bold bg-clip-text text-transparent bg-gradient-to-r ${gradient}`}>{b.value}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: Sidebar -->
      <div class="space-y-6">

        <!-- Calculator CTA -->
        {term.relatedCalculator && (
          <div class={`bg-gradient-to-br from-purple-600/20 to-pink-600/20 rounded-3xl border border-purple-500/30 p-6`}>
            <Icon name="tabler:calculator" class="w-8 h-8 text-purple-400 mb-3" />
            <h3 class="text-lg font-bold text-white mb-2">Try the Calculator</h3>
            <p class="text-sm text-gray-400 mb-4">Use our free tool to calculate {term.abbreviation || term.term} for your campaigns.</p>
            <a
              href={term.relatedCalculator.href}
              class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold text-sm hover:opacity-90 transition-opacity"
            >
              {term.relatedCalculator.label}
              <Icon name="tabler:arrow-right" class="w-4 h-4" />
            </a>
          </div>
        )}

        <!-- Related terms -->
        {relatedTerms.length > 0 && (
          <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-6">
            <h3 class="text-base font-bold text-white mb-4 flex items-center gap-2">
              <Icon name="tabler:link" class="w-5 h-5 text-purple-400" />
              Related Terms
            </h3>
            <div class="space-y-2">
              {relatedTerms.map((related) => (
                <a
                  href={`/glossary/${related.slug}`}
                  class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5 hover:border-purple-500/30 hover:bg-purple-500/10 transition-all group"
                >
                  <div>
                    {related.abbreviation && (
                      <span class="text-xs font-bold text-purple-400">{related.abbreviation} — </span>
                    )}
                    <span class="text-sm text-gray-300 group-hover:text-white transition-colors">{related.term}</span>
                  </div>
                  <Icon name="tabler:chevron-right" class="w-4 h-4 text-gray-600 group-hover:text-purple-400 transition-colors" />
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Comparisons CTA -->
        <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-6">
          <h3 class="text-base font-bold text-white mb-2 flex items-center gap-2">
            <Icon name="tabler:arrows-exchange" class="w-5 h-5 text-blue-400" />
            Compare Metrics
          </h3>
          <p class="text-xs text-gray-400 mb-4">See how {term.abbreviation || term.term} stacks up against other key metrics.</p>
          <a
            href="/compare"
            class="flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-gray-300 text-sm font-medium hover:border-blue-500/50 hover:text-white transition-all"
          >
            View All Comparisons
            <Icon name="tabler:arrow-right" class="w-4 h-4" />
          </a>
        </div>

        <!-- Browse all -->
        <div class="bg-white/5 backdrop-blur-2xl rounded-3xl border border-white/10 p-6">
          <h3 class="text-base font-bold text-white mb-2 flex items-center gap-2">
            <Icon name="tabler:book-2" class="w-5 h-5 text-gray-400" />
            Full Glossary
          </h3>
          <p class="text-xs text-gray-400 mb-4">Browse all {glossaryTerms.length} advertising and marketing terms.</p>
          <a
            href="/glossary"
            class="flex items-center justify-center gap-2 w-full py-2.5 px-4 rounded-xl bg-white/5 border border-white/10 text-gray-300 text-sm font-medium hover:border-white/20 hover:text-white transition-all"
          >
            View All Terms
            <Icon name="tabler:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>

    <!-- Related tools -->
    <div class="mt-12">
      <RelatedTools currentPage={`/glossary/${term.slug}`} />
    </div>
  </section>
</Layout>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
